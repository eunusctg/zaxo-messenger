# ========== Database ==========
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ========== LiveKit (Audio/Video Calls) ==========
LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_PROJECT_ID=your_project_id

# ========== Firebase ==========
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY_ID=your_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
FIREBASE_FCM_VAPID_KEY=your_vapid_key

# ========== Firebase Client (NEXT_PUBLIC_ for browser) ==========
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FIREBASE_FCM_VAPID_KEY=your_vapid_key

# ========== LiveKit Client (NEXT_PUBLIC_ for browser) ==========
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-url.livekit.cloud

# ========== R2 Client ==========
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-domain.com

# ========== Cloudflare R2 (Media Storage) ==========
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=zaxo
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_CUSTOM_DOMAIN=your-r2-domain.com
R2_PUBLIC_URL=https://your-r2-domain.com
